  "slots": [
    {
      "name": "id",
      "definition_uri": "https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema/id",
      "description": "Auto-generated integer identifier.",
      "from_schema": "https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema",
      "slot_uri": "https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema/id",
      "identifier": true,
      "owner": "ZappEntity",
      "domain_of": [
        "ZappEntity"
      ],
      "range": "integer",
      "required": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "term_uri",
      "definition_uri": "https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema/term_uri",
      "description": "The URI of the phenotype ontology term.",
      "from_schema": "https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema",
      "slot_uri": "https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema/term_uri",
      "identifier": true,
      "owner": "ExposureType",
      "domain_of": [
        "PhenotypeTerm",
        "ExposureRoute",
        "ExposureType"
      ],
      "range": "uriorcurie",
      "required": true,
      "@type": "SlotDefinition"
    },
    {
