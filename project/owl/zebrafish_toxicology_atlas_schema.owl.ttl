    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:PhenotypeTerm a owl:Class ;
    rdfs:label "PhenotypeTerm" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty zebrafish_toxicology_atlas_schema:term_uri ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:term_uri ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:term_label ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:term_uri ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:term_label ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty zebrafish_toxicology_atlas_schema:term_label ],
        zebrafish_toxicology_atlas_schema:OntologyEntity ;
    skos:definition "A phenotype ontology term from the Zebrafish Phenotype ontology (ZP)." ;
    skos:exactMatch biolink:PhenotypicFeature ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:Regimen a owl:Class ;
    rdfs:label "Regimen" ;
