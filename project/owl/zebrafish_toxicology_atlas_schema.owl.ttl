            owl:onProperty zebrafish_toxicology_atlas_schema:scale_bar ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:magnification ],
        zebrafish_toxicology_atlas_schema:ZappEntity ;
