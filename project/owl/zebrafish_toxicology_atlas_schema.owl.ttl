            owl:onProperty zebrafish_toxicology_atlas_schema:control_type ],
        zebrafish_toxicology_atlas_schema:ZappEntity ;
    skos:definition "A subject serves as a reference for assessing phenotypic outcome in the phenotype observation set." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:Experiment a owl:Class ;
    rdfs:label "Experiment" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty zebrafish_toxicology_atlas_schema:rearing_condition_comment ],
        [ a owl:Restriction ;
            owl:allValuesFrom zebrafish_toxicology_atlas_schema:Fish ;
            owl:onProperty zebrafish_toxicology_atlas_schema:fish ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:rearing_condition_comment ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:standard_rearing_condition ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:exposure_event ],
        [ a owl:Restriction ;
            owl:allValuesFrom zebrafish_toxicology_atlas_schema:Control ;
            owl:onProperty zebrafish_toxicology_atlas_schema:control ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:standard_rearing_condition ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:rearing_condition_comment ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:boolean ;
            owl:onProperty zebrafish_toxicology_atlas_schema:standard_rearing_condition ],
        [ a owl:Restriction ;
            owl:allValuesFrom zebrafish_toxicology_atlas_schema:ExposureEvent ;
            owl:onProperty zebrafish_toxicology_atlas_schema:exposure_event ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:control ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:fish ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:fish ],
        zebrafish_toxicology_atlas_schema:ZappEntity ;
    skos:definition "A group of observations (phenotypic outcomes and their control) that are linked by a common exposure event and subject, and that are part of a study." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:ExposureEvent a owl:Class ;
    rdfs:label "ExposureEvent" ;
