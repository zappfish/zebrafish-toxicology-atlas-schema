@prefix CHEBI: <http://purl.obolibrary.org/obo/CHEBI_> .
@prefix EXO: <http://purl.obolibrary.org/obo/EXO_> .
@prefix PUBCHEM.COMPOUND: <https://identifiers.org/pubchem.compound/> .
@prefix UMLS: <https://uts.nlm.nih.gov/uts/umls/concept/> .
@prefix UNII: <https://fdasis.nlm.nih.gov/srs/unii/> .
@prefix biolink: <https://w3id.org/biolink/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix linkml: <https://w3id.org/linkml/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix zebrafish_toxicology_atlas_schema: <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema/> .

<https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema.owl.ttl> a owl:Ontology ;
    rdfs:label "zebrafish-toxicology-atlas-schema" ;
    dcterms:license "MIT" ;
    dcterms:title "zebrafish-toxicology-atlas-schema" ;
    rdfs:seeAlso <https://sierra-moxon.github.io/zebrafish-toxicology-atlas-schema> ;
    skos:definition "Schema to represent metadatcha associated with the Zebrafish Toxicology Atlas" .

zebrafish_toxicology_atlas_schema:control_id a owl:DatatypeProperty ;
    rdfs:label "control_id" ;
    rdfs:range xsd:string ;
    skos:definition "Identifier for the control, used to link control images to specific controls." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:Study a owl:Class ;
    rdfs:label "Study" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:lab ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty zebrafish_toxicology_atlas_schema:publication ],
        [ a owl:Restriction ;
            owl:allValuesFrom zebrafish_toxicology_atlas_schema:Experiment ;
            owl:onProperty zebrafish_toxicology_atlas_schema:experiment ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:annotator ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:publication ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( xsd:anyURI [ a rdfs:Datatype ;
                                owl:onDatatype xsd:string ;
                                owl:withRestrictions ( [ xsd:pattern "^ORCID:[0-9]{4}-[0-9]{4}-[0-9]{4}-[0-9]{3}[0-9X]$" ] ) ] ) ] ;
            owl:onProperty zebrafish_toxicology_atlas_schema:annotator ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:experiment ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( xsd:anyURI [ a rdfs:Datatype ;
                                owl:onDatatype xsd:string ;
                                owl:withRestrictions ( [ xsd:pattern "^ZFIN:ZDB-LAB-[0-9]+-[0-9]+$" ] ) ] ) ] ;
            owl:onProperty zebrafish_toxicology_atlas_schema:lab ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:publication ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:lab ],
        zebrafish_toxicology_atlas_schema:ZappEntity ;
    skos:definition "A toxicological investigation, including the experimental conditions and phenotypic outcomes, with information provenance." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:ZfinEntity a owl:Class ;
    rdfs:label "ZfinEntity" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:zfin_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( xsd:string [ a rdfs:Datatype ;
                                owl:onDatatype xsd:string ;
                                owl:withRestrictions ( [ xsd:pattern "^ZFIN:ZDB-[A-Z]+-\\d{6}-\\d+$" ] ) ] ) ] ;
            owl:onProperty zebrafish_toxicology_atlas_schema:zfin_id ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:zfin_id ],
        linkml:ClassDefinition,
        zebrafish_toxicology_atlas_schema:Fish ;
    skos:definition "Entities with ZFIN database identifiers." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

