        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:term_label ],
        zebrafish_toxicology_atlas_schema:OntologyEntity ;
    skos:definition """An exposure-type term from ECTO.
""" ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:Fish a owl:Class ;
    rdfs:label "Fish" ;
