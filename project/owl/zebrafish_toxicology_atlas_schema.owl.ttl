zebrafish_toxicology_atlas_schema:annotator a owl:DatatypeProperty ;
    rdfs:label "annotator" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:anyURI [ a rdfs:Datatype ;
                        owl:onDatatype xsd:string ;
                        owl:withRestrictions ( [ xsd:pattern "^ORCID:[0-9]{4}-[0-9]{4}-[0-9]{4}-[0-9]{3}[0-9X]$" ] ) ] ) ] ;
    skos:definition "ORCID identifier of the indidvidual submitting the study data." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:control a owl:ObjectProperty ;
    rdfs:label "control" ;
    rdfs:range zebrafish_toxicology_atlas_schema:Control ;
    skos:definition "An observation that serves as the reference for assessing phenotypic outcome." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:experiment a owl:ObjectProperty ;
    rdfs:label "experiment" ;
    rdfs:range zebrafish_toxicology_atlas_schema:Experiment ;
    skos:definition "The experiment in a study." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:exposure_event a owl:ObjectProperty ;
    rdfs:label "exposure_event" ;
    rdfs:range zebrafish_toxicology_atlas_schema:ExposureEvent ;
    skos:definition "The exposure event in an experiment." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:image a owl:ObjectProperty ;
    rdfs:label "image" ;
    rdfs:range zebrafish_toxicology_atlas_schema:Image ;
    skos:definition "Images associated with this observation." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:phenotype a owl:ObjectProperty ;
    rdfs:label "phenotype" ;
    rdfs:range zebrafish_toxicology_atlas_schema:Phenotype ;
    skos:definition "The phenotype observed." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:phenotype_observation a owl:ObjectProperty ;
    rdfs:label "phenotype_observation" ;
    rdfs:range zebrafish_toxicology_atlas_schema:PhenotypeObservationSet ;
    skos:definition "The phenotype observation resulting from an exposure event." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:stressor a owl:ObjectProperty ;
    rdfs:label "stressor" ;
    rdfs:range zebrafish_toxicology_atlas_schema:StressorChemical ;
    skos:definition "Substance, chemical or toxicant that elicits a response (a phenotype) in a subject when encountered through exposure." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:synonym a owl:DatatypeProperty ;
    rdfs:label "synonym" ;
    rdfs:range xsd:string ;
    skos:definition "Other names for the chemical." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:vehicle a owl:ObjectProperty ;
    rdfs:label "vehicle" ;
    rdfs:range zebrafish_toxicology_atlas_schema:VehicleOfTransmission ;
    skos:definition "The substance or medium used to deliver a stressor." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:Control a owl:Class ;
    rdfs:label "Control" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
