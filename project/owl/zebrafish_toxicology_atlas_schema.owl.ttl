            owl:onProperty zebrafish_toxicology_atlas_schema:chemical_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom zebrafish_toxicology_atlas_schema:ManufacturerEnum ;
            owl:onProperty zebrafish_toxicology_atlas_schema:manufacturer ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:cas_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty zebrafish_toxicology_atlas_schema:cas_id ],
        [ a owl:Restriction ;
