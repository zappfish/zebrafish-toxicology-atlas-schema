        [ a owl:Restriction ;
            owl:allValuesFrom zebrafish_toxicology_atlas_schema:VehicleOfTransmission ;
            owl:onProperty zebrafish_toxicology_atlas_schema:vehicle_if_treated ],
        [ a owl:Restriction ;
            owl:allValuesFrom zebrafish_toxicology_atlas_schema:ControlImage ;
            owl:onProperty zebrafish_toxicology_atlas_schema:control_image ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty zebrafish_toxicology_atlas_schema:control_type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:control_image ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:comment ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:control_type ],
        [ a owl:Restriction ;
