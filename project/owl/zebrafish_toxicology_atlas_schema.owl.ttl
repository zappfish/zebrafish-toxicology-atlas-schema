            owl:onProperty zebrafish_toxicology_atlas_schema:phenotype_term_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:severity ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:prevalence ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:stage ],
        [ a owl:Restriction ;
            owl:allValuesFrom zebrafish_toxicology_atlas_schema:PhenotypeTerm ;
            owl:onProperty zebrafish_toxicology_atlas_schema:phenotype_term_id ],
        [ a owl:Restriction ;
