    rdfs:range xsd:string ;
    skos:definition "CAS identifier for the chemical." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:chemical_id a owl:DatatypeProperty ;
    rdfs:label "chemical_id" ;
    rdfs:range xsd:anyURI ;
    skos:definition "Chemical identifier (e.g., a CHEBI or other ontology URI) for the chemical." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:chemical_name a owl:DatatypeProperty ;
    rdfs:label "chemical_name" ;
    rdfs:range xsd:string ;
    skos:definition "Name of the chemical." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:control_type a owl:DatatypeProperty ;
    rdfs:label "control_type" ;
    rdfs:range xsd:string ;
    skos:definition "Type of control (e.g., wildtype vs mutant, treated vs untreated)." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:exposure_end_stage a owl:DatatypeProperty ;
    rdfs:label "exposure_end_stage" ;
    rdfs:range xsd:anyURI ;
    skos:definition "The developmental stage of fish when exposure ended." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:exposure_regimen_type a owl:ObjectProperty ;
    rdfs:label "exposure_regimen_type" ;
    rdfs:range zebrafish_toxicology_atlas_schema:ExposureRegimenTypeEnum ;
    skos:definition "The type of exposure regimen (e.g., continuous or repeated)." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:exposure_start_stage a owl:DatatypeProperty ;
    rdfs:label "exposure_start_stage" ;
    rdfs:range xsd:anyURI ;
    skos:definition "The developmental stage of fish when exposure started." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:exposure_type a owl:ObjectProperty ;
    rdfs:label "exposure_type" ;
    rdfs:range zebrafish_toxicology_atlas_schema:ExposureType ;
    skos:definition "An instance of exposure specifying the type of stressor a subject was exposed to." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:fish a owl:ObjectProperty ;
    rdfs:label "fish" ;
    rdfs:range zebrafish_toxicology_atlas_schema:Fish ;
    skos:definition "The fish subject of the experiment." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:id a owl:DatatypeProperty ;
    rdfs:label "id" ;
    rdfs:range xsd:integer ;
    skos:definition "Auto-generated integer identifier." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:individual_exposure_duration a owl:ObjectProperty ;
    rdfs:label "individual_exposure_duration" ;
    rdfs:range zebrafish_toxicology_atlas_schema:QuantityValue ;
    skos:definition "Individual exposure duration." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:interval_between_individual_exposures a owl:ObjectProperty ;
    rdfs:label "interval_between_individual_exposures" ;
    rdfs:range zebrafish_toxicology_atlas_schema:QuantityValue ;
    skos:definition "Interval between individual exposures." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:lab a owl:DatatypeProperty ;
    rdfs:label "lab" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:anyURI [ a rdfs:Datatype ;
                        owl:onDatatype xsd:string ;
                        owl:withRestrictions ( [ xsd:pattern "^ZFIN:ZDB-LAB-[0-9]+-[0-9]+$" ] ) ] ) ] ;
    skos:definition "ZFIN lab identifier of the laboratory that produced the study data." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:name a owl:DatatypeProperty ;
    rdfs:label "name" ;
    skos:definition "Name or label of an entity." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:number_of_individual_exposure a owl:DatatypeProperty ;
    rdfs:label "number_of_individual_exposure" ;
    rdfs:range xsd:integer ;
    skos:definition "Total number of individual exposures." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:numeric_value a owl:DatatypeProperty ;
    rdfs:label "numeric_value" ;
    skos:definition "The numeric value of the quantity value." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:phenotype_comments a owl:DatatypeProperty ;
    rdfs:label "phenotype_comments" ;
    rdfs:range xsd:string ;
    skos:definition "Comments about the phenotype in the control image." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:phenotype_id a owl:DatatypeProperty ;
    rdfs:label "phenotype_id" ;
    rdfs:range xsd:string ;
    skos:definition "Foreign key reference to the PhenotypeObservationSet uuid (for database representation)." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:phenotype_term_id a owl:ObjectProperty ;
    rdfs:label "phenotype_term_id" ;
    rdfs:range zebrafish_toxicology_atlas_schema:PhenotypeTerm ;
    skos:definition "The phenotype ontology term." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:prevalence a owl:ObjectProperty ;
    rdfs:label "prevalence" ;
    rdfs:range zebrafish_toxicology_atlas_schema:QuantityValue ;
    skos:definition "The percentage of subject exhibiting this phenotype." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:publication a owl:DatatypeProperty ;
    rdfs:label "publication" ;
    rdfs:range xsd:string ;
    skos:definition "The publication identifier (e.g., PMID, DOI) for the study or \"not published\" if the study is unpublished." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:rearing_condition_comment a owl:DatatypeProperty ;
    rdfs:label "rearing_condition_comment" ;
    rdfs:range xsd:string ;
    skos:definition "Comments on rearing conditions, for example, about how conditions deviated from standard parameters." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:regimen a owl:ObjectProperty ;
    rdfs:label "regimen" ;
    rdfs:range zebrafish_toxicology_atlas_schema:Regimen ;
    skos:definition "The regimen for the exposure." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:route a owl:ObjectProperty ;
    rdfs:label "route" ;
    rdfs:range zebrafish_toxicology_atlas_schema:ExposureRoute ;
    skos:definition "The route of exposure." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:severity a owl:ObjectProperty ;
    rdfs:label "severity" ;
    rdfs:range zebrafish_toxicology_atlas_schema:SeverityEnum ;
    skos:definition "The intensity of the observed phenotype." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:stage a owl:DatatypeProperty ;
    rdfs:label "stage" ;
    rdfs:range xsd:anyURI ;
    skos:definition "The developmental stage of fish when the phenotype was observed." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:standard_rearing_condition a owl:DatatypeProperty ;
    rdfs:label "standard_rearing_condition" ;
    rdfs:range xsd:boolean ;
    skos:definition "An indication of whether the subject was maintained under standard conditions, which are the established, consistent environmental and husbandry parameters (such as temperature, lighting, diet, and housing) designed to minimize variability and ensure reproducibility in experiments." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:total_exposure_duration a owl:ObjectProperty ;
    rdfs:label "total_exposure_duration" ;
    rdfs:range zebrafish_toxicology_atlas_schema:QuantityValue ;
    skos:definition "Time between first and last individual exposure." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:unit a owl:DatatypeProperty ;
    rdfs:label "unit" ;
    skos:definition "The unit of the quantity value." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:vehicle_if_treated a owl:ObjectProperty ;
    rdfs:label "vehicle_if_treated" ;
    rdfs:range zebrafish_toxicology_atlas_schema:VehicleOfTransmission ;
    skos:definition "The vehicle used in a control." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:vehicle_type a owl:ObjectProperty ;
    rdfs:label "vehicle_type" ;
    rdfs:range zebrafish_toxicology_atlas_schema:VehicleEnum ;
    skos:definition "The type of vehicle used to deliver a stressor, drawn from a controlled vocabulary." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:zfin_id a owl:DatatypeProperty ;
    rdfs:label "zfin_id" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:string [ a rdfs:Datatype ;
                        owl:onDatatype xsd:string ;
                        owl:withRestrictions ( [ xsd:pattern "^ZFIN:ZDB-[A-Z]+-\\d{6}-\\d+$" ] ) ] ) ] ;
    skos:definition "ZFIN database identifier." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:ControlImage a owl:Class ;
    rdfs:label "ControlImage" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:resolution ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty zebrafish_toxicology_atlas_schema:scale_bar ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:phenotype_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:magnification ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:resolution ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:scale_bar ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:magnification ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty zebrafish_toxicology_atlas_schema:resolution ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:scale_bar ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:phenotype_comments ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty zebrafish_toxicology_atlas_schema:magnification ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:phenotype_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:phenotype_comments ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty zebrafish_toxicology_atlas_schema:phenotype_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty zebrafish_toxicology_atlas_schema:phenotype_comments ],
        zebrafish_toxicology_atlas_schema:ZappEntity ;
    skos:definition "An image associated with a control, taken at the same developmental stage as the corresponding phenotype observation." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:ExposureRegimenTypeEnum a owl:Class ;
    rdfs:label "ExposureRegimenTypeEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( EXO:0000109 EXO:0000110 ) ;
    skos:definition "An enumeration of exposure regimen types." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> ;
    linkml:permissible_values EXO:0000109,
        EXO:0000110 .

zebrafish_toxicology_atlas_schema:control_image a owl:ObjectProperty ;
    rdfs:label "control_image" ;
    rdfs:range zebrafish_toxicology_atlas_schema:ControlImage ;
    skos:definition "Image associated with this control." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:SeverityEnum a owl:Class ;
    rdfs:label "SeverityEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema/SeverityEnum#mild> <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema/SeverityEnum#moderate> <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema/SeverityEnum#severe> ) ;
    skos:definition "An enumeration of severity levels for phenotypes." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> ;
    linkml:permissible_values <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema/SeverityEnum#mild>,
        <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema/SeverityEnum#moderate>,
        <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema/SeverityEnum#severe> .

zebrafish_toxicology_atlas_schema:VehicleOfTransmission a owl:Class ;
    rdfs:label "VehicleOfTransmission" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:concentration ],
        [ a owl:Restriction ;
            owl:allValuesFrom zebrafish_toxicology_atlas_schema:QuantityValue ;
            owl:onProperty zebrafish_toxicology_atlas_schema:concentration ],
        [ a owl:Restriction ;
            owl:allValuesFrom zebrafish_toxicology_atlas_schema:ManufacturerEnum ;
            owl:onProperty zebrafish_toxicology_atlas_schema:manufacturer ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:manufacturer ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:concentration ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:comment ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty zebrafish_toxicology_atlas_schema:comment ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:vehicle_type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:comment ],
        [ a owl:Restriction ;
            owl:allValuesFrom zebrafish_toxicology_atlas_schema:VehicleEnum ;
            owl:onProperty zebrafish_toxicology_atlas_schema:vehicle_type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:vehicle_type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:manufacturer ],
        zebrafish_toxicology_atlas_schema:ZappEntity ;
    skos:definition "The substance or medium used to deliver a stressor to a subject during an exposure event." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:concentration a owl:ObjectProperty ;
    rdfs:label "concentration" ;
    rdfs:range zebrafish_toxicology_atlas_schema:QuantityValue ;
    skos:definition "The dose or concentration of the chemical to which the subject was exposed to." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:magnification a owl:DatatypeProperty ;
    rdfs:label "magnification" ;
    rdfs:range xsd:string ;
    skos:definition "The factor by which a microscope enlarges the apparent size of a subject compared to its actual size." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:manufacturer a owl:ObjectProperty ;
    rdfs:label "manufacturer" ;
    rdfs:range zebrafish_toxicology_atlas_schema:ManufacturerEnum ;
    skos:definition "The manufacturer or supplier of the chemical." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:resolution a owl:DatatypeProperty ;
    rdfs:label "resolution" ;
    rdfs:range xsd:string ;
    skos:definition "The level of detail in the image." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:scale_bar a owl:DatatypeProperty ;
    rdfs:label "scale_bar" ;
    rdfs:range xsd:string ;
    skos:definition "Scale bar information, including the physical length it represents and the unit of measurement." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:term_label a owl:DatatypeProperty ;
    rdfs:label "term_label" ;
    rdfs:range xsd:string ;
    skos:definition "The human-readable label for the phenotype ontology term." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:term_uri a owl:DatatypeProperty ;
    rdfs:label "term_uri" ;
    rdfs:range xsd:anyURI ;
    skos:definition "The URI of the phenotype ontology term." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:QuantityValue a owl:Class ;
    rdfs:label "QuantityValue" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:numeric_value ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty zebrafish_toxicology_atlas_schema:numeric_value ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:unit ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty zebrafish_toxicology_atlas_schema:unit ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:numeric_value ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:unit ],
        linkml:ClassDefinition ;
    skos:definition "A value of an attribute that is quantitative and measurable, expressed as a combination of a unit and a numeric value" ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:ZappEntity a owl:Class ;
    rdfs:label "ZappEntity" ;
    rdfs:subClassOf [ owl:unionOf ( zebrafish_toxicology_atlas_schema:Control zebrafish_toxicology_atlas_schema:ControlImage zebrafish_toxicology_atlas_schema:Experiment zebrafish_toxicology_atlas_schema:ExposureEvent zebrafish_toxicology_atlas_schema:Image zebrafish_toxicology_atlas_schema:Phenotype zebrafish_toxicology_atlas_schema:PhenotypeObservationSet zebrafish_toxicology_atlas_schema:Regimen zebrafish_toxicology_atlas_schema:StressorChemical zebrafish_toxicology_atlas_schema:Study zebrafish_toxicology_atlas_schema:VehicleOfTransmission ) ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty zebrafish_toxicology_atlas_schema:id ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:id ],
        linkml:ClassDefinition ;
    skos:definition "Internal entities with auto-generated integer IDs." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:comment a owl:DatatypeProperty ;
    rdfs:label "comment" ;
    rdfs:range xsd:string ;
    skos:definition "Additional comments." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:VehicleEnum a owl:Class ;
    rdfs:label "VehicleEnum" ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( CHEBI:15347 CHEBI:38472 UMLS:C0036774 CHEBI:28398 CHEBI:23456 CHEBI:17741 CHEBI:28262 <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema/VehicleEnum#embryonic_media> CHEBI:16236 CHEBI:17754 CHEBI:17824 CHEBI:17790 CHEBI:53448 PUBCHEM.COMPOUND:24978514 CHEBI:30742 CHEBI:16997 UNII:3XK098O8ZW CHEBI:15377 ) ;
    skos:definition "An enumeration of vehicles used to deliver stressors in exposure events." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> ;
    linkml:permissible_values CHEBI:15347,
        CHEBI:15377,
        CHEBI:16236,
        CHEBI:16997,
        CHEBI:17741,
        CHEBI:17754,
        CHEBI:17790,
        CHEBI:17824,
        CHEBI:23456,
        CHEBI:28262,
        CHEBI:28398,
        CHEBI:30742,
        CHEBI:38472,
        CHEBI:53448,
        UNII:3XK098O8ZW,
        PUBCHEM.COMPOUND:24978514,
        UMLS:C0036774,
        <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema/VehicleEnum#embryonic_media> .

zebrafish_toxicology_atlas_schema:ManufacturerEnum a owl:Class ;
