            owl:onProperty zebrafish_toxicology_atlas_schema:stressor ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:exposure_end_stage ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:exposure_end_stage ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:exposure_start_stage ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty zebrafish_toxicology_atlas_schema:exposure_end_stage ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:phenotype_observation ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty zebrafish_toxicology_atlas_schema:comment ],
        zebrafish_toxicology_atlas_schema:ZappEntity ;
    skos:definition "An occurrence in a study where a subject is exposed to a stressor under defined conditions." ;
    skos:exactMatch biolink:ExposureEvent ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:ExposureRoute a owl:Class ;
    rdfs:label "ExposureRoute" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty zebrafish_toxicology_atlas_schema:term_uri ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:term_uri ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty zebrafish_toxicology_atlas_schema:term_label ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:term_label ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:term_uri ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty zebrafish_toxicology_atlas_schema:term_label ],
        zebrafish_toxicology_atlas_schema:OntologyEntity ;
    skos:definition """A route-of-exposure term. Term URIs are expected to be reachable from
EXO:0000154 (route of exposure) in the EXO ontology.
""" ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:ExposureType a owl:Class ;
