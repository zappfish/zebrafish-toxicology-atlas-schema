zebrafish_toxicology_atlas_schema:OntologyEntity a owl:Class ;
    rdfs:label "OntologyEntity" ;
    rdfs:subClassOf [ owl:unionOf ( zebrafish_toxicology_atlas_schema:ExposureRoute zebrafish_toxicology_atlas_schema:ExposureType zebrafish_toxicology_atlas_schema:PhenotypeTerm ) ],
        linkml:ClassDefinition ;
    skos:definition "Entities representing ontology terms with URI identifiers." ;
    skos:inScheme <https://w3id.org/sierra-moxon/zebrafish-toxicology-atlas-schema> .

zebrafish_toxicology_atlas_schema:Phenotype a owl:Class ;
    rdfs:label "Phenotype" ;
    rdfs:subClassOf [ a owl:Restriction ;
